              "type": "array",
            },
          },
        ],
        "outputs": [
          {
            "id": "eggnogAnnotations",
            "type": "File",
          },
          {
            "id": "eggnogReport",
            "type": "File",
          },
        ],
        "requirements": [
          {
            "class": "SubworkflowFeatureRequirement",
          },
          {
            "class": "InlineJavascriptRequirement",
          },
          {
            "class": "StepInputExpressionRequirement",
          },
        ],
        "steps": [],
      },
    },
    {
      "id": "emapper-pre-workflow",
