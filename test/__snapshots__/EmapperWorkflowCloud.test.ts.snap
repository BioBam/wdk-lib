        "class": "CommandLineTool",
        "cwlVersion": "v1.2",
        "id": "emapper-pre-workflow",
        "inputs": [
          {
            "doc": "Serialized Parameters File",
            "id": "paramsDataFile",
            "inputBinding": {
              "prefix": "--paramsDataFile",
            },
            "type": "File",
          },
          {
